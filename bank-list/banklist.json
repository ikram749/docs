{
  "openapi": "3.0.3",
  "info": {
    "title": "SayaBeliPay API",
    "description": "API for retrieving available FPX banks and other payment-related services.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://sayabelipay.com/api",
      "description": "API Environment"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/fpx_bank_list": {
      "get": {
        "summary": "Retrieve FPX bank",
        "description": "Retrieve FPX bank listing with their display name and online/offline status.",
        "operationId": "getFpxBankList",
        "x-mint": {
          "metadata": {
            "title": "FPX Bank List",
            "description": "Retrieve available FPX banks with their status (online/offline).",
            "og:title": "List of FPX Banks"
          }
        },
        "responses": {
          "200": {
            "description": "List of banks and their availability status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FpxBankListResponse"
                },
                "example": {
                  "status": 200,
                  "banks": {
                    "AFBB": { "name": "Affin Bank", "status": "offline" },
                    "RHBB": { "name": "RHB Bank", "status": "online" },
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "Internal server error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use your client_id as username and client_secret as password."
      }
    },
    "schemas": {
      "FpxBankListResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "integer", "example": 200 },
          "banks": {
            "type": "object",
            "description": "Key-value list of banks where the key is the bank identifier.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Bank"
            }
          }
        }
      },
      "Bank": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Bank display name", "example": "Maybank2U" },
          "status": { "type": "string", "description": "Availability status of the bank", "enum": ["online", "offline"], "example": "online" }
        },
        "required": ["name", "status"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "Internal server error" }
        },
        "required": ["message"]
      }
    }
  }
}